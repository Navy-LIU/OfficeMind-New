# OfficeMind Environment Configuration
# Copy to .env and fill in values

# ── DGX Spark Node ────────────────────────────────────────────────────────────
DGX_HOST=106.13.186.155
DGX_PORT=6059
DGX_USER=xsuper

# ── vLLM Service URLs (running on DGX Spark) ─────────────────────────────────
VLLM_BASE_URL=http://localhost:8000/v1
VLM_BASE_URL=http://localhost:8001/v1
EMBED_BASE_URL=http://localhost:8002/v1
VLLM_API_KEY=EMPTY

# ── Model Names ───────────────────────────────────────────────────────────────
LLM_MODEL=Qwen3-Thinking
VLM_MODEL=Qwen2.5-VL
EMBED_MODEL=Qwen3-Embedding

# ── Model Paths on DGX Spark ─────────────────────────────────────────────────
MODELS_DIR=/home/xsuper/models
LLM_PATH=/home/xsuper/models/Qwen3-next-80b-a3b-thinking
VLM_PATH=/home/xsuper/models/qwen/Qwen2.5-VL-7B-Instruct
EMBED_PATH=/home/xsuper/models/Qwen/Qwen3-Embedding

# ── OfficeMind API ────────────────────────────────────────────────────────────
PORT=7860
HOST=0.0.0.0

# ── RAG ───────────────────────────────────────────────────────────────────────
CHROMA_DB_PATH=./data/chroma_db
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5

