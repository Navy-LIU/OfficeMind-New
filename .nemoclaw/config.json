{
  "sandbox": {
    "name": "officemind",
    "description": "Enterprise AI Office Automation on DGX Spark GB10 — Fully Local, No Cloud Dependencies"
  },
  "inference": {
    "provider": "local",
    "base_url": "http://localhost:8000/v1",
    "model": "Qwen3-next-80b-a3b-thinking",
    "api_key": "EMPTY",
    "options": {
      "temperature": 0.1,
      "max_tokens": 8192,
      "top_p": 0.9
    }
  },
  "vlm": {
    "provider": "local",
    "base_url": "http://localhost:8001/v1",
    "model": "Qwen2.5-VL-7B-Instruct",
    "api_key": "EMPTY",
    "options": {
      "max_tokens": 4096
    }
  },
  "embedding": {
    "provider": "local",
    "base_url": "http://localhost:8002/v1",
    "model": "bge-m3",
    "api_key": "EMPTY"
  },
  "reranker": {
    "provider": "local",
    "base_url": "http://localhost:8002/v1",
    "model": "bge-reranker-v2-m3",
    "api_key": "EMPTY"
  },
  "agents": {
    "main": {
      "agent_file": ".agents/main/agent.md",
      "tools": ["bash", "read_file", "write_file", "http_request"]
    }
  },
  "platform": {
    "hardware": "NVIDIA DGX Spark GB10",
    "architecture": "aarch64",
    "memory_gb": 128,
    "models_dir": "/home/xsuper/models",
    "inference_engine": "TensorRT-LLM",
    "fully_local": true
  }
}
